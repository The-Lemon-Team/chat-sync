// Chat-Sync: Offline Telegram client & personal journal manager
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ChatType {
  SAVED_MESSAGES
  GROUP
  CHANNEL
  OFFLINE_JOURNAL
}

/// Режим синхронизации чата-форка (на уровне чата)
enum ChatSyncMode {
  LIVE
  SCHEDULED
  MANUAL
  OFFLINE_ONLY
}

/// Статус синхронизации отдельного сообщения
enum MessageSyncStatus {
  PENDING
  SYNCED
  OFFLINE_ONLY
}

/// Роль аккаунта в иерархии пользователя
enum TelegramAccountRole {
  HUB  /// Hub Telegram Account — один на пользователя, реальная TG-сессия
  CHAT /// Chat Account — рабочее пространство, сколько угодно
}

/// Как был создан Chat Account
enum ChatAccountSource {
  HUB_CLONE /// Полная оффлайн-копия Hub на момент создания
  CLEAN     /// Пустой аккаунт без копии Hub
}

// ─── Models ──────────────────────────────────────────────────────────────────

/// Пользователь приложения. Владелец Hub и Chat Accounts.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  telegramAccounts TelegramAccount[]

  @@map("users")
}

/// Hub Telegram Account или Chat Account.
/// HUB: phone + sessionString (GramJS), один на пользователя.
/// CHAT: displayName, без TG-сессии — платформа для работы с чатами.
model TelegramAccount {
  id            String              @id @default(cuid())
  role          TelegramAccountRole
  phone         String?             /// только для HUB
  sessionString String?             @db.Text /// только для HUB
  displayName   String?             /// только для CHAT
  source        ChatAccountSource?  /// только для CHAT
  hubDetachedAt DateTime?           /// Hub удалён/отключён — sync из Hub недоступен
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Hub, из которого была сделана копия (для HUB_CLONE)
  hubSourceId  String?
  hubSource    TelegramAccount?  @relation("HubToChatAccounts", fields: [hubSourceId], references: [id], onDelete: SetNull)
  chatAccounts TelegramAccount[] @relation("HubToChatAccounts")

  chatForks ChatFork[]

  @@unique([userId, phone])
  @@index([userId])
  @@index([userId, role])
  @@index([hubSourceId])
  @@map("telegram_accounts")
}

/// Локальный «форк» Telegram-чата или автономный оффлайн-журнал.
model ChatFork {
  id             String       @id @default(cuid())
  telegramChatId String?      /// null для чисто оффлайн-журналов (OFFLINE_JOURNAL)
  title          String
  type           ChatType
  syncMode       ChatSyncMode @default(MANUAL)
  syncInterval   Int?         /// интервал в минутах (для SCHEDULED)
  lastSyncedAt   DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  accountId String
  account   TelegramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  messages Message[]

  @@unique([accountId, telegramChatId])
  @@index([accountId])
  @@index([syncMode])
  @@map("chat_forks")
}

/// Сообщение внутри чата-форка.
/// localId — стабильный UUID на клиенте; telegramMessageId — ID в Telegram (nullable для оффлайн).
model Message {
  id                String            @id @default(cuid())
  localId           String            @default(uuid()) @db.Uuid
  telegramMessageId BigInt?
  text              String            @db.Text
  syncStatus        MessageSyncStatus @default(PENDING)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  chatForkId String
  chatFork   ChatFork @relation(fields: [chatForkId], references: [id], onDelete: Cascade)

  mediaFiles MediaFile[]

  @@unique([chatForkId, localId])
  @@unique([chatForkId, telegramMessageId])
  @@index([chatForkId, createdAt])
  @@index([syncStatus])
  @@map("messages")
}

/// Медиафайл, привязанный к сообщению.
model MediaFile {
  id             String  @id @default(cuid())
  localPath      String  /// путь на диске сервера
  telegramFileId String?
  mimeType       String?
  fileSize       BigInt?

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("media_files")
}
