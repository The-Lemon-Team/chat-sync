# PostgreSQL из docker-compose (npm run db:up)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/chat_sync?schema=public"

# Получить на https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

PORT=3000

# Локальное хранилище медиа (скачивается SyncService)
MEDIA_STORAGE_PATH=./storage/media

# JWT для авторизации пользователей приложения
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d
